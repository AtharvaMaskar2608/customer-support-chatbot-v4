# ---------------------------------------------------------------------------
# Choice FinX customer-support chatbot — configuration.
# Copy to `.env` and fill in real values. Every supported key is documented
# here. Nothing is hardcoded in source; all runtime settings come from here.
# ---------------------------------------------------------------------------

# --- Anthropic (agent) ---
ANTHROPIC_API_KEY=            # required
ANTHROPIC_MODEL=claude-sonnet-4-5   # optional; this is the default

# --- Embeddings (OpenAI) ---
EMBEDDING_MODEL=text-embedding-3-large   # optional; this is the default
# Provide either EMBEDDING_API_KEY or OPENAI_API_KEY (OPENAI_API_KEY is used as a fallback).
EMBEDDING_API_KEY=           # required (or set OPENAI_API_KEY)
OPENAI_API_KEY=              # fallback for EMBEDDING_API_KEY

# --- Postgres (read-only qa_chunks) ---
# Either set DATABASE_URL, or set the discrete DB_* keys below. If DATABASE_URL
# is provided it populates any DB_* key you leave blank.
DATABASE_URL=                # e.g. postgresql://user:pass@localhost:5433/customer-support-chatbot
DB_HOST=localhost
DB_PORT=5433
DB_NAME=customer-support-chatbot
DB_USER=atharva
DB_PASSWORD=

# --- FINX report services (P2 report tools) ---
FINX_REPORTS_BASE_URL=https://finxomne.choiceindia.com   # CML report host
# Contract Note may live on a different host; defaults to FINX_REPORTS_BASE_URL if unset.
FINX_CONTRACT_NOTE_BASE_URL=https://finx.choiceindia.com

# --- Tracing / evals ---
TRACING_ENABLED=false
CONFIDENT_API_KEY=           # required only when TRACING_ENABLED=true

# --- Cost card ---
USD_TO_INR=95.0              # USD->INR conversion for the per-message cost card

# --- API / CORS ---
FRONTEND_ORIGIN=http://localhost:5173   # allowed CORS origin for the P5 API
